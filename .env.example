# =====================================================
# 腾讯云 CloudBase（云开发）配置
# 国内 CDN，国内访问速度跟微信打开网页一样快
# =====================================================

# CloudBase 环境 ID
# CloudBase 控制台 → 环境 → 环境总览 可以看到
# 形如：bycjh5-abc123def456
VITE_CLOUDBASE_ENV_ID=bycjh5-d9g7g8uuk3d4137d2

# CloudBase 云函数 HTTP 触发访问的 base URL
# 部署完 adminLogin 和 properties 两个云函数并在「环境管理 → HTTP 访问服务」里
# 添加 /adminLogin 和 /properties 两条路由后，CloudBase 会分配一个默认域名：
#   https://bycjh5-d9g7g8uuk3d4137d2-1341239145.ap-shanghai.app.tcloudbase.com
# 复制那个域名（不带路径），填到下面
# 注意：
#   - 不要带末尾的 /
#   - 区域后缀按你环境实际位置来（ap-shanghai / ap-guangzhou / ap-beijing）
VITE_CLOUDBASE_HTTP_URL=https://bycjh5-d9g7g8uuk3d4137d2-1341239145.ap-shanghai.app.tcloudbase.com

# =====================================================
# 高德地图 JS API Key（V4 起改用高德，不用腾讯地图）
# 申请：https://lbs.amap.com/dev/key/app
# 应用类型必须选「Web 端 (JS API)」
# 域名白名单填 *（允许所有域名）
# =====================================================
VITE_AMAP_KEY=your-amap-js-api-key
