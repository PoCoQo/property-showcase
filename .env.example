# =====================================================
# 腾讯云 CloudBase（云开发）配置
# 国内 CDN，国内访问速度跟微信打开网页一样快
# =====================================================

# CloudBase 环境 ID
# CloudBase 控制台 → 环境 → 环境总览 可以看到
# 形如：bycjh5-abc123def456
VITE_CLOUDBASE_ENV_ID=bycjh5-d9g7g8uuk3d4137d2

# CloudBase 云函数 HTTP 触发访问的 base URL
# 部署完 adminLogin 和 properties 两个云函数并启用 HTTP 触发后，
# CloudBase 控制台会显示类似：
#   https://bycjh5-d9g7g8uuk3d4137d2.ap-shanghai.tencentscf.com
# 复制那个域名（不带路径），填到下面
# 注意：
#   - 不要带末尾的 /
#   - 这是浏览器直接 fetch 的地址，必须能跨域（CORS 已在云函数里处理）
#   - 区域后缀按你环境实际位置来（ap-shanghai / ap-guangzhou / ap-beijing）
VITE_CLOUDBASE_HTTP_URL=https://bycjh5-d9g7g8uuk3d4137d2.ap-shanghai.tencentscf.com

# 腾讯地图 Key（不变）
# 申请：https://lbs.qq.com/dev/console/key
VITE_TENCENT_MAP_KEY=PT0BZ-26WKC-JEC2A-ABL5M-RXAH6-6ABPL
